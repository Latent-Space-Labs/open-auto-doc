{
  "name": "@latent-space-labs/auto-doc-generator",
  "version": "0.3.2",
  "description": "MDX content and site scaffolding for open-auto-doc",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "handlebars": "^4.7.8",
    "fs-extra": "^11.3.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.12.0",
    "@types/fs-extra": "^11.0.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Latent-Space-Labs/open-auto-doc.git",
    "directory": "packages/generator"
  },
  "license": "MIT"
}
