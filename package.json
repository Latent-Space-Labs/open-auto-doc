{
  "name": "open-auto-doc-monorepo",
  "private": true,
  "workspaces": [
    "packages/analyzer",
    "packages/generator",
    "packages/cli"
  ],
  "scripts": {
    "build": "npm run build -w packages/analyzer -w packages/generator -w packages/cli",
    "dev": "npm run dev --workspaces --if-present",
    "clean": "rm -rf packages/*/dist",
    "release": "node scripts/release.mjs",
    "local": "node packages/cli/dist/index.js init"
  },
  "engines": {
    "node": ">=18"
  }
}
